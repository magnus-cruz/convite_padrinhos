<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <!-- Fundo com gradiente -->
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#667eea;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#764ba2;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#f093fb;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Retângulo de fundo -->
  <rect width="800" height="600" fill="url(#grad1)"/>
  
  <!-- Ícone de grupo de pessoas (Font Awesome style) -->
  <g transform="translate(400, 250)">
    <!-- Pessoa central -->
    <circle cx="0" cy="-50" r="40" fill="white" opacity="0.9"/>
    <ellipse cx="0" cy="20" rx="60" ry="80" fill="white" opacity="0.9"/>
    
    <!-- Pessoa esquerda -->
    <circle cx="-120" cy="-40" r="35" fill="white" opacity="0.7"/>
    <ellipse cx="-120" cy="15" rx="50" ry="70" fill="white" opacity="0.7"/>
    
    <!-- Pessoa direita -->
    <circle cx="120" cy="-40" r="35" fill="white" opacity="0.7"/>
    <ellipse cx="120" cy="15" rx="50" ry="70" fill="white" opacity="0.7"/>
  </g>
  
  <!-- Ícone de câmera sobreposto -->
  <g transform="translate(650, 100)">
    <rect x="-30" y="-20" width="60" height="50" rx="5" fill="white" opacity="0.3"/>
    <circle cx="0" cy="5" r="15" fill="white" opacity="0.5"/>
    <rect x="-40" y="-25" width="20" height="10" rx="3" fill="white" opacity="0.3"/>
  </g>
  
  <!-- Texto -->
  <text x="400" y="480" font-family="Arial, sans-serif" font-size="32" font-weight="bold" 
        text-anchor="middle" fill="white">
    Adicione sua foto aqui
  </text>
  
  <text x="400" y="520" font-family="Arial, sans-serif" font-size="20" 
        text-anchor="middle" fill="white" opacity="0.8">
    Substitua este arquivo por: turma.jpg
  </text>
  
  <!-- Ícone de upload -->
  <g transform="translate(400, 560)">
    <path d="M -20,0 L 0,-20 L 20,0 M 0,-20 L 0,20" 
          stroke="white" stroke-width="4" fill="none" opacity="0.7"/>
  </g>
</svg>
